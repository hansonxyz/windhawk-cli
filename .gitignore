# Large / downloaded / derived artifacts (reproducible; not source)
# - downloads/ : official installer (windhawk_setup_offline.exe, ~149 MB)
# - windhawk-portable/ : extracted runtime + locally-built binaries (test rig)
# - tools/ : fetched helpers (nuget.exe)
/downloads/
/windhawk-portable/
/tools/

# Upstream Windhawk clone.
# Reproducible via `git clone https://github.com/ramensoftware/windhawk` (see CLAUDE.md).
# Will be vendored/submoduled here once we modify the fork's native source.
/windhawk/

# .NET build outputs
[Bb]in/
[Oo]bj/
*.user

# Built whcli.exe / whsetup.exe / installer package are derived artifacts
/dist/

# Code-signing PRIVATE keys — never commit. (The public certs/*.cer IS committed,
# it's what the fleet trusts; the private key stays in the signing machine's store.)
*.pfx
*.snk
*.key

# NOTE: profile.json (the canonical deployment profile) and mods/ (pinned mod
# sources) ARE committed on purpose -- they are the reproducible provisioning input.

# Ad-hoc / machine-specific profile exports (the reviewed profile is committed explicitly)
*.local.json

# OS / editor cruft
Thumbs.db
desktop.ini
.vs/
