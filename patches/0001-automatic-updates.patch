diff --git a/src/windhawk/app/functions.cpp b/src/windhawk/app/functions.cpp
index 8de915c..d801f22 100644
--- a/src/windhawk/app/functions.cpp
+++ b/src/windhawk/app/functions.cpp
@@ -2,6 +2,8 @@
 
 #include "functions.h"
 
+#include "logger.h"
+
 namespace Functions {
 
 namespace {
@@ -615,4 +617,58 @@ void ApplyDialogLayoutRtl(CWindow wnd, bool isLayoutRtl) {
     wnd.InvalidateRect(NULL);
 }
 
+void RunModUpdater(bool wait, bool noReload) {
+    // Locate whcli.exe next to this executable; its directory is the install root
+    // (contains windhawk.ini) that whcli operates on.
+    WCHAR exePath[MAX_PATH];
+    DWORD len = GetModuleFileName(nullptr, exePath, ARRAYSIZE(exePath));
+    if (len == 0 || len >= ARRAYSIZE(exePath)) {
+        LOG(L"RunModUpdater: GetModuleFileName failed (%u)", GetLastError());
+        return;
+    }
+
+    std::wstring dir(exePath, len);
+    size_t slash = dir.find_last_of(L'\\');
+    if (slash == std::wstring::npos) {
+        LOG(L"RunModUpdater: unexpected exe path");
+        return;
+    }
+    dir.resize(slash);
+
+    std::wstring whcli = dir + L"\\whcli.exe";
+    if (GetFileAttributes(whcli.c_str()) == INVALID_FILE_ATTRIBUTES) {
+        LOG(L"RunModUpdater: whcli.exe not found at %s, skipping", whcli.c_str());
+        return;
+    }
+
+    std::wstring cmdLine = L"\"" + whcli + L"\" update --root \"" + dir + L"\"";
+    if (noReload) {
+        cmdLine += L" --no-reload";
+    }
+
+    STARTUPINFO si{};
+    si.cb = sizeof(si);
+    PROCESS_INFORMATION pi{};
+
+    // CreateProcess may write to the command-line buffer; pass a mutable copy.
+    std::wstring cmdLineMutable = cmdLine;
+    if (!CreateProcess(whcli.c_str(), cmdLineMutable.data(), nullptr, nullptr,
+                       FALSE, CREATE_NO_WINDOW, nullptr, dir.c_str(), &si, &pi)) {
+        LOG(L"RunModUpdater: CreateProcess failed (%u)", GetLastError());
+        return;
+    }
+
+    CloseHandle(pi.hThread);
+
+    if (wait) {
+        // Bound the pre-engine wait so a slow/hung update can't block startup forever.
+        constexpr DWORD kUpdaterTimeout = 1000 * 60 * 5;  // 5 min
+        if (WaitForSingleObject(pi.hProcess, kUpdaterTimeout) == WAIT_TIMEOUT) {
+            LOG(L"RunModUpdater: updater timed out, continuing startup");
+        }
+    }
+
+    CloseHandle(pi.hProcess);
+}
+
 }  // namespace Functions
